---
/**
 * Lite YouTube embed with WebP poster (Lighthouse next-gen formats).
 * Poster uses vi_webp/ID/hqdefault.webp with JPG fallback; iframe loads on click.
 */
interface Props {
  id: string;
  title?: string;
}

const { id, title = "YouTube video" } = Astro.props;
const posterWebP = `https://i.ytimg.com/vi_webp/${id}/hqdefault.webp`;
const posterJpg = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
---

<div class="lite-youtube-webp" data-videoid={id}>
  <a
    class="lite-youtube-webp__link"
    href={`https://www.youtube.com/watch?v=${id}`}
    aria-label={title}
    data-title={title}
  >
    <picture class="lite-youtube-webp__poster">
      <source srcset={posterWebP} type="image/webp" />
      <img
        src={posterJpg}
        alt=""
        width="480"
        height="360"
        loading="lazy"
        decoding="async"
      />
    </picture>
    <span class="lite-youtube-webp__playbtn" aria-hidden="true"></span>
  </a>
</div>

<style>
  .lite-youtube-webp {
    position: relative;
    display: block;
    contain: content;
    background-color: #000;
    aspect-ratio: 16 / 9;
  }
  .lite-youtube-webp__link {
    display: block;
    text-decoration: none;
    position: absolute;
    inset: 0;
  }
  .lite-youtube-webp__poster {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 0;
    border: none;
  }
  .lite-youtube-webp__poster img,
  .lite-youtube-webp__poster source {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .lite-youtube-webp__playbtn {
    position: absolute;
    inset: 0;
    width: 68px;
    height: 48px;
    margin: auto;
    background: rgba(33, 33, 33, 0.9);
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.1s ease;
  }
  .lite-youtube-webp__playbtn::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    border-style: solid;
    border-width: 11px 0 11px 19px;
    border-color: transparent transparent transparent #fff;
    margin-left: 4px;
  }
  .lite-youtube-webp__link:hover .lite-youtube-webp__playbtn {
    background: #f00;
  }
  .lite-youtube-webp iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>

<script>
  const initLiteYouTube = () => {
    document.querySelectorAll<HTMLElement>(".lite-youtube-webp").forEach((wrapper) => {
      const link = wrapper.querySelector(".lite-youtube-webp__link");
      if (!link || wrapper.querySelector("iframe")) return;

      const loadIframe = (e: Event) => {
        e.preventDefault();
        const id = wrapper.dataset.videoid;
        const title = link?.getAttribute("data-title") ?? "YouTube video";
        if (!id) return;

        const iframe = document.createElement("iframe");
        iframe.title = title;
        iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
        iframe.allow = "accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture";
        iframe.allowFullscreen = true;
        wrapper.appendChild(iframe);
        wrapper.classList.add("lite-youtube-webp--loaded");
      };

      link.addEventListener("click", loadIframe, { once: true });
    });
  };
  initLiteYouTube();
  document.addEventListener("astro:page-load", initLiteYouTube);
</script>
