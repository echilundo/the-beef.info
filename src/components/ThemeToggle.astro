---
import SunIcon from "@components/icons/SunIcon.astro";
import MoonIcon from "@components/icons/MoonIcon.astro";

interface Props {
  class?: string;
  /** Unique suffix for button IDs to avoid duplicate-id when multiple toggles exist (e.g. nav + footer). */
  idSuffix?: string;
}

const { class: className = "", idSuffix = "default" } = Astro.props;
const lightId = `light-theme-button-${idSuffix}`;
const darkId = `dark-theme-button-${idSuffix}`;
---

<div class={`flex flex-wrap gap-1 items-center ${className}`} role="group" aria-label="Theme selection" data-theme-toggle={idSuffix}>
  <!-- Light Theme Button -->
  <button
    id={lightId}
    aria-label="Switch to light theme"
    aria-pressed="false"
    class="group size-8 flex items-center justify-center rounded-full light-theme-button focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
    type="button"
  >
    <SunIcon />
  </button>

  <!-- Dark Theme Button -->
  <button
    id={darkId}
    aria-label="Switch to dark theme"
    aria-pressed="false"
    class="group size-8 flex items-center justify-center rounded-full dark-theme-button focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
    type="button"
  >
    <MoonIcon />
  </button>
</div>

<script>
  // * Theme toggle: one script updates all instances (nav + footer) to avoid duplicate IDs.
  const updateThemeButtons = () => {
    const isDark = document.documentElement.classList.contains("dark");
    document.querySelectorAll<HTMLElement>("[data-theme-toggle]").forEach((wrapper) => {
      const lightButton = wrapper.querySelector<HTMLElement>(".light-theme-button");
      const darkButton = wrapper.querySelector<HTMLElement>(".dark-theme-button");
      if (lightButton && darkButton) {
        lightButton.style.opacity = isDark ? "0.5" : "1";
        darkButton.style.opacity = isDark ? "1" : "0.5";
        lightButton.setAttribute("aria-pressed", (!isDark).toString());
        darkButton.setAttribute("aria-pressed", isDark.toString());
        lightButton.setAttribute("aria-label", isDark ? "Switch to light theme" : "Currently using light theme");
        darkButton.setAttribute("aria-label", isDark ? "Currently using dark theme" : "Switch to dark theme");
      }
    });
  };

  const announce = (message: string) => {
    const fm = (window as unknown as Record<string, unknown>).focusManager as { announce?: (msg: string) => void } | undefined;
    if (fm?.announce) {
      fm.announce(message);
    }
  };

  const setTheme = (theme: "light" | "dark") => {
    localStorage.setItem("theme", theme);
    document.documentElement.classList.toggle("dark", theme === "dark");
    updateThemeButtons();
    announce(`Switched to ${theme} theme`);
  };

  const handleKeyDown = (event: KeyboardEvent, lightButton: HTMLElement, darkButton: HTMLElement) => {
    if (event.key === "ArrowLeft" || event.key === "ArrowRight") {
      event.preventDefault();
      const currentTheme = document.documentElement.classList.contains("dark") ? "dark" : "light";
      const newTheme = event.key === "ArrowLeft" ? "light" : "dark";
      if (currentTheme !== newTheme) {
        setTheme(newTheme);
        const targetButton = newTheme === "light" ? lightButton : darkButton;
        targetButton?.focus();
      }
    }
  };

  document.querySelectorAll<HTMLElement>("[data-theme-toggle]").forEach((wrapper) => {
    const lightButton = wrapper.querySelector<HTMLElement>(".light-theme-button");
    const darkButton = wrapper.querySelector<HTMLElement>(".dark-theme-button");
    if (!lightButton || !darkButton) return;
    lightButton.addEventListener("click", () => setTheme("light"));
    darkButton.addEventListener("click", () => setTheme("dark"));
    lightButton.addEventListener("keydown", (e) => handleKeyDown(e, lightButton, darkButton));
    darkButton.addEventListener("keydown", (e) => handleKeyDown(e, lightButton, darkButton));
  });

  updateThemeButtons();
  document.addEventListener("astro:page-load", updateThemeButtons);

  const observer = new MutationObserver(updateThemeButtons);
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["class"]
  });

  document.addEventListener("astro:before-preparation", () => {
    observer.disconnect();
  });
</script>
