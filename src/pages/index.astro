---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import TimelineItem from "@components/TimelineItem.astro";
import { getWork, getChunkCount, TIMELINE } from "@lib/timeline";
import { WORK } from "@consts";

const work = await getWork();
const initialWork = work.slice(0, TIMELINE.INITIAL_COUNT);
const chunkCount = getChunkCount(work.length);
---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <h1 class="font-semibold text-black dark:text-white text-2xl">
        Timeline
      </h1>      
      <div class="prose dark:prose-invert">
        <p class="text-lg font-medium">
          The full timeline of the greatest beef 🥩 saga in hip-hop.
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-300">
          All of it below.
        </p>
      </div>
      
      <ul
        id="timeline-list"
        class="flex flex-col space-y-12"
        aria-label="Timeline of events"
      >
        {initialWork.map((entry, index) => (
          <TimelineItem
            entry={entry}
            showHr={index !== initialWork.length - 1 || work.length > TIMELINE.INITIAL_COUNT}
          />
        ))}
      </ul>
      {chunkCount > 0 && (
        <div class="mt-10 flex justify-center" id="timeline-load-more-wrap">
          <button
            type="button"
            id="timeline-load-more"
            class="rounded bg-stone-200 px-4 py-2 text-sm font-medium text-stone-800 hover:bg-stone-300 dark:bg-stone-700 dark:text-stone-200 dark:hover:bg-stone-600"
            data-chunk-count={chunkCount}
          >
            Load more
          </button>
        </div>
      )}
    </div>
  </Container>
</PageLayout>

<style>
  .timeline-item {
    transform: translateY(20px);
    will-change: opacity, transform;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-item {
      transition: none;
    }
  }

  article {
    contain: content;
  }
</style>

<script>
  const initTimeline = () => {
    const items = document.querySelectorAll(".timeline-item");
    if (!items.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            io.unobserve(entry.target);
          }
        });
      },
      { rootMargin: "50px" }
    );

    items.forEach((item) => io.observe(item));
  };

  const initLoadMore = () => {
    const btn = document.getElementById("timeline-load-more") as HTMLButtonElement | null;
    const list = document.getElementById("timeline-list");
    const wrap = document.getElementById("timeline-load-more-wrap");
    if (!btn || !list || !wrap) return;

    let nextChunk = 1;
    const chunkCount = Number(btn.dataset.chunkCount) || 0;

    btn.addEventListener("click", async () => {
      if (nextChunk > chunkCount) return;
      btn.disabled = true;
      btn.textContent = "Loading…";
      try {
        const res = await fetch(`/timeline-chunk/${nextChunk}`);
        const html = await res.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, "text/html");
        const nodes = doc.body.querySelectorAll("li");
        nodes.forEach((node) => list.appendChild(node.cloneNode(true)));
        nextChunk += 1;
        if (nextChunk > chunkCount) {
          wrap.remove();
        } else {
          btn.disabled = false;
          btn.textContent = "Load more";
        }
        initTimeline();
      } catch {
        btn.disabled = false;
        btn.textContent = "Load more";
      }
    });
  };

  if ("requestIdleCallback" in window) {
    requestIdleCallback(initTimeline, { timeout: 500 });
    requestIdleCallback(initLoadMore, { timeout: 500 });
  } else {
    setTimeout(initTimeline, 1);
    setTimeout(initLoadMore, 1);
  }

  document.addEventListener("astro:after-swap", () => {
    initTimeline();
    initLoadMore();
  });
</script>
