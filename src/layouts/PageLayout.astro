

---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import FloatingButtons from "@components/FloatingButtons.astro";
import ErrorBoundary from "@components/ErrorBoundary.astro";
import LoadingIndicator from "@components/LoadingIndicator.astro";
import SkipLinks from "@components/SkipLinks.astro";
import FocusManager from "@components/FocusManager.astro";
import { SITE } from "@consts";

const { title, description } = Astro.props;
const selineToken = import.meta.env.PUBLIC_SELINE_TOKEN ?? "";
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={`${title} | ${SITE.NAME}`} description={description} />

    <!-- Resource hints for better performance -->
    <link rel="preconnect" href="https://cdn.seline.so" />
    <link rel="preconnect" href="https://platform.twitter.com" />
    <link rel="dns-prefetch" href="https://platform.twitter.com" />
    <link rel="dns-prefetch" href="https://i.ytimg.com" />

    <!-- * theme-color tells mobile browsers what color to tint the browser chrome. -->
    <meta name="theme-color" content="#f5f5f4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1c1917" media="(prefers-color-scheme: dark)" />
  </head>
  <body class="bg-stone-100 dark:bg-stone-900 text-black dark:text-white">
    <SkipLinks />

    <Header transition:persist />
    <main id="main-content" aria-label="Main content">
      <slot />
    </main>
    <Footer />

    <FloatingButtons transition:persist />

    <ErrorBoundary />

    <LoadingIndicator />

    <FocusManager />

    <!-- * Seline loads after paint to avoid competing with FCP/LCP (Lighthouse main-thread). -->
    <script is:inline define:vars={{ selineToken }}>
      (function () {
        function loadSeline() {
          var s = document.createElement("script");
          s.src = "https://cdn.seline.so/seline.js";
          s.async = true;
          if (selineToken) s.dataset.token = selineToken;
          document.body.appendChild(s);
        }
        if (document.readyState === "complete") {
          if (window.requestIdleCallback) requestIdleCallback(loadSeline, { timeout: 2000 });
          else setTimeout(loadSeline, 1);
        } else {
          window.addEventListener("load", function () {
            if (window.requestIdleCallback) requestIdleCallback(loadSeline, { timeout: 2000 });
            else setTimeout(loadSeline, 1);
          });
        }
      })();
    </script>

    <!-- Optimized Scripts -->
    <script>
      import "/src/scripts/page-layout.js";
    </script>
  </body>
</html>
